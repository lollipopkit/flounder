# Build context hygiene for docker/flounder.Dockerfile.
# node_modules and dist are rebuilt inside the builder stage.
.git
node_modules
dist
.npm-cache

# Local secrets and runtime state — never bake into the image.
.env
.env.*
.flounder
deploy-backup-*

# Skills tooling / editor / agent scratch.
.agents
.claude
skills-lock.json

# Local run artifacts and logs.
runs
reports
*.log
